tainer\" data-e-type=\"container\" data-settings=\"{&quot;jet_parallax_layout_list&quot;:[]}\">\n\t\t\t\t<div class=\"elementor-element elementor-element-9456e22 elementor-widget elementor-widget-heading\" data-id=\"9456e22\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">What Our Happy Clients say about us<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-402fa01 elementor-widget elementor-widget-text-editor\" data-id=\"402fa01\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p>Our clients love working with us, just read what they have to say!<\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-1e7a839 elementor-widget elementor-widget-jet-testimonials\" data-id=\"1e7a839\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;slides_to_show&quot;:&quot;2&quot;,&quot;slides_to_show_tablet&quot;:&quot;1&quot;,&quot;slides_to_scroll&quot;:&quot;1&quot;}\" data-widget_type=\"jet-testimonials.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<div class=\"elementor-jet-testimonials jet-elements\">\n<div class=\"jet-testimonials\">\n\t<div class=\"jet-testimonials__instance elementor-slick-slider\"data-settings='{&quot;autoplaySpeed&quot;:2000,&quot;autoplay&quot;:true,&quot;infinite&quot;:true,&quot;centerMode&quot;:false,&quot;centerPadding&quot;:&quot;50px&quot;,&quot;adaptiveHeight&quot;:true,&quot;pauseOnHover&quot;:true,&quot;speed&quot;:500,&quot;arrows&quot;:false,&quot;dots&quot;:true,&quot;slidesToScroll&quot;:1,&quot;prevArrow&quot;:&quot;.jet-testimonial__prev-arrow-1e7a839&quot;,&quot;nextArrow&quot;:&quot;.jet-testimonial__next-arrow-1e7a839&quot;,&quot;rtl&quot;:false}' dir=\"ltr\"><div class=\"jet-testimonials__item\">\n\t<div class=\"jet-testimonials__item-inner\">\n\t\t\t\t<div class=\"jet-testimonials__content\"><h5 class=\"jet-testimonials__title\">An Unforgettable Luxury Safari<\/h5><div class=\"jet-testimonials__comment\">Cache Tours and Safaris  delivered the perfect balance of adventure and comfort. Every detail was handled with care, from our guide\u2019s knowledge to the stunning lodges. Seeing the Big Five up close while staying in pure luxury made this a trip of a lifetime.<\/div><div class=\"jet-testimonials__name\"><span>Sarah & David M., USA<\/span><\/div><div class=\"jet-testimonials__rating\" data-rating=\"5\"><i aria-hidden=\"true\" data-star=\"fas fa-star\" data-active-star=\"fas fa-star\"><\/i><i aria-hidden=\"true\" data-star=\"fas fa-star\" data-active-star=\"fas fa-star\"><\/i><i aria-hidden=\"true\" data-star=\"fas fa-star\" data-active-star=\"fas fa-star\"><\/i><i aria-hidden=\"true\" data-star=\"fas fa-star\" data-active-star=\"fas fa-star\"><\/i><i aria-hidden=\"true\" data-star=\"fas fa-star\" data-active-star=\"fas fa-star\"><\/i><\/div><\/div>\n\t\t\t<\/div>\n<\/div>\n\n<div class=\"jet-testimonials__item\">\n\t<div class=\"jet-testimonials__item-inner\">\n\t\t\t\t<div class=\"jet-testimonials__content\"><h5 class=\"jet-testimonials__title\">First-Class From Start to Finish<\/h5><div class=\"jet-testimonials__comment\">Booking with Cache Tours and Safaris  was seamless, and the experience was flawless. Our private guide was exceptional, the accommodations were world-class, and the itinerary was thrilling yet relaxed. It\u2019s rare to find such luxury in adventure travel.<\/div><div class=\"jet-testimonials__name\"><span>Mark & Elena P., Australia<\/span><\/div><div class=\"jet-testimonials__rating\" data-rating=\"5\"><i aria-hidden=\"true\" data-star=\"fas fa-star\" data-active-star=\"fas fa-star\"><\/i><i aria-hidden=\"true\" data-star=\"fas fa-sta